# Lumivision configuration
# Copy this file to .env (same directory as docker-compose.yml) and edit.
# .env is gitignored — your secrets never end up in the repo.

# --- Required -------------------------------------------------------------

# First-run admin account. Created once on the first container start;
# changing these later has no effect on an existing database.
LUMIVISION_ADMIN_PASSWORD=

# --- Recommended for production --------------------------------------------

# Your public hostname(s), comma-separated. "*" allows any host.
LUMIVISION_ALLOWED_HOSTS=vision.example.com

# Required when served over HTTPS through the Virtualmin proxy.
LUMIVISION_TRUSTED_ORIGINS=https://vision.example.com

# --- Optional (defaults shown) ---------------------------------------------

LUMIVISION_ADMIN_USER=admin
LUMIVISION_ADMIN_EMAIL=
LUMIVISION_HOST_PORT=8018
LUMIVISION_MAX_UPLOAD_MB=250
LUMIVISION_TIME_ZONE=UTC
LUMIVISION_WORKERS=3
